<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- Background split -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#1A2540">



        <LinearLayout

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="80dp"
            android:paddingEnd="28dp"
            android:paddingBottom="40dp"
            android:background="#1A2540">

            <!-- Logo -->

            <!-- Login Card -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="138dp"
                android:layout_marginBottom="0dp"
                android:gravity="start">

                <ImageView
                    android:layout_width="106dp"
                    android:layout_height="119dp"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/cl" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1A2030"
                android:elevation="10dp"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome Back"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="Login to continue"
                    android:textColor="#8AB4D4"
                    android:textSize="13sp" />

                <!-- Username -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Email ID"
                    android:textColor="#8AB4D4"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/input_bg"
                        android:hint="Enter email"
                        android:inputType="text"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:singleLine="true"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#6B7C93" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                    </ScrollView>
                </FrameLayout>

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Password"
                    android:textColor="#8AB4D4"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/input_bg"
                        android:hint="Enter password"
                        android:inputType="textPassword"
                        android:paddingStart="18dp"
                        android:paddingEnd="52dp"
                        android:singleLine="true"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#6B7C93" />

                    <ImageButton
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="14dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_eye_off"
                        android:tint="#8AB4D4" />
                </FrameLayout>

                <!-- Show Password -->
                <CheckBox
                    android:id="@+id/cbShowPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:buttonTint="#4A8FD4"
                    android:text="Show Password"
                    android:textColor="#B5C7E3" />

                <!-- Forgot Password -->
                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginBottom="22dp"
                    android:text="Forgot Password?"
                    android:textColor="#4A8FD4"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Login Button -->
                <Button
                    android:id="@+id/loginButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/approve_btn"
                    android:backgroundTint="@null"
                    android:elevation="4dp"
                    android:text="LOGIN"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Cyber Animations -->
    <ImageView
        android:id="@+id/cyberRing1"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-20dp"
        android:layout_marginEnd="-20dp"
        android:src="@drawable/ic_ring_outer"
        android:alpha="0.12" />

    <ImageView
        android:id="@+id/cyberRing2"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-20dp"
        android:layout_marginBottom="70dp"
        android:src="@drawable/ic_ring_inner"
        android:alpha="0.12" />

    <ImageView
        android:id="@+id/cyberRing3"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="70dp"
        android:src="@drawable/ic_ring_outer"
        android:alpha="0.08" />

    <ImageView
        android:id="@+id/cyberGear1"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-20dp"
        android:layout_marginBottom="40dp"
        android:src="@drawable/ic_gear_pattern"
        android:alpha="0.10" />

    <ImageView
        android:id="@+id/cyberGear2"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="top|start"
        android:layout_marginTop="40dp"
        android:layout_marginStart="-10dp"
        android:src="@drawable/ic_gear_pattern"
        android:alpha="0.08" />

    <!-- Main Content -->

</FrameLayout>

