<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- Background split -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:background="#1A2030"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="7"
            android:background="#0D2B5E"/>
    </LinearLayout>

    <!-- Spinning rings -->
    <ImageView
        android:id="@+id/fpRing1"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="end|top"
        android:layout_marginEnd="-30dp"
        android:layout_marginTop="-30dp"
        android:src="@drawable/ic_ring_outer"
        android:alpha="0.15"/>

    <ImageView
        android:id="@+id/fpRing2"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="60dp"
        android:src="@drawable/ic_ring_inner"
        android:alpha="0.12"/>

    <ImageView
        android:id="@+id/fpGear"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="-10dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_gear_pattern"
        android:alpha="0.09"/>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="70dp"
            android:paddingBottom="40dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp">

            <!-- Logo -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/caveo_logo"
                android:scaleType="fitCenter"
                android:layout_marginBottom="32dp"/>

            <!-- Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:elevation="12dp"
                android:padding="24dp">

                <!-- Back button -->
                <LinearLayout
                    android:id="@+id/btnBackToLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#8592;"
                        android:textColor="#4A8FD4"
                        android:textSize="18sp"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Back to Login"
                        android:textColor="#4A8FD4"
                        android:textSize="13sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset Password"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter your email to receive a reset link"
                    android:textColor="#8AB4D4"
                    android:textSize="12sp"
                    android:layout_marginBottom="24dp"/>

                <!-- Username -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#8AB4D4"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">

                    <EditText
                        android:id="@+id/etForgotUsername"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/input_bg"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#4A6080"
                        android:hint="Enter your email ID"
                        android:textSize="14sp"
                        android:paddingStart="44dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:singleLine="true"/>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="12dp"
                        android:src="@drawable/ic_user_field"
                        android:alpha="0.5"/>
                </FrameLayout>

                <!-- Status message (shown after submit) -->
                <TextView
                    android:id="@+id/tvResetStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"/>

                <!-- Submit button -->
                <Button
                    android:id="@+id/btnSendReset"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="SEND RESET LINK"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:backgroundTint="@null"
                    android:background="@drawable/approve_btn"
                    android:elevation="4dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>

